<%- include("partials/head") %>
<main id="smooth-wrapper">
  <div class="container">
    <header class="header" id="header">
      <nav class="navbar container">
        <a href="/" class="brand">BLOGAT</a>
        <div class="burger" id="burger">
          <span class="burger-line"></span>
          <span class="burger-line"></span>
          <span class="burger-line"></span>
        </div>
        <span class="overlay"></span>
        <div class="menu" id="menu">
          <ul class="menu-inner">
            <li class="menu-item">
              <a class="menu-link" id="home" href="/">Home</a>
            </li>
            <li class="menu-item">
              <a class="menu-link" id="aboutUs" href="/About">About</a>
            </li>
            <li class="menu-item">
              <a class="menu-link" id="contactUs" href="/Contact">Contact</a>
            </li>
            <li class="menu-item">
              <a class="menu-link" id="adminPanel" href="/admin/adminPanel"
                >Admin Panel</a
              >
            </li>
            <li class="menu-item">
              <a class="menu-link" id="createBlog" href="/blogCreation"
                >Create Blog</a
              >
            </li>
            <li class="menu-item">
              <a class="menu-link" id="createBlog" href="/Analytics"
                >Analytics</a
              >
            </li>
          </ul>
        </div>
        <span><i class="bx bx-search search-toggle"></i></span>
        <div class="search-block">
          <form class="search-form">
            <span><i class="bx bx-arrow-back search-cancel"></i></span>
            <input
              type="search"
              name="search"
              class="search-input"
              placeholder="Search here..."
            />
          </form>
        </div>
      </nav>
    </header>
    <form action="/blog/blogCreation" method="post">
      <div class="row1">
        <input
          type="text"
          name="author"
          placeholder="Author Name"
          list="author"
          value="Ali Raza"
          required
        />
        <input
          type="text"
          list="category-list"
          name="category"
          placeholder="Category Name"
          required
        />
        <datalist id="category-list">
          <option value="Technology"></option>
          <option value="Travel"></option>
          <option value="Sports"></option>
          <option value="News"></option>
          <option value="Education"></option>
          <option value="Weather"></option>
          <option value="SEO"></option>
          <option value="Trends"></option>
        </datalist>
        <input
          type="text"
          list="category-list"
          name="tag"
          placeholder="Tag Name"
          required
        />
        <datalist id="author">
          <option value="Ali Raza"></option>
        </datalist>
      </div>
      <div class="row2">
        <input type="text" name="title" placeholder="Main Title" required />
        <textarea
          name="description"
          id="description"
          placeholder="Main Description"
          required
        ></textarea>
      </div>
      <div class="row3">
        <input
          type="text"
          name="secondTitle"
          placeholder="Second Title"
          required
        />
        <textarea
          name="secondDescription"
          id="description"
          placeholder="Second Description"
          required
        ></textarea>
      </div>
      <div class="row4">
        <input type="text" name="thirdTitle" placeholder="Third Title" />
        <textarea
          name="thirdDescription"
          id="description"
          placeholder="Third Description"
        ></textarea>
      </div>
      <div class="row5">
        <input type="text" name="forthTitle" placeholder="Fourth Title" />
        <textarea
          name="forthDescription"
          id="description"
          placeholder="Fourth Description"
        ></textarea>
      </div>
      <div class="row6">
        <input type="text" name="fifthTitle" placeholder="Fifth Title" />
        <textarea
          name="fifthDescription"
          id="description"
          placeholder="Fifth Description"
        ></textarea>
      </div>
      <div class="row7">
        <input type="text" name="imageUri" placeholder="Image url" required />
        <datalist id="category-list">
          <option value="Technology"></option>
          <option value="Travel"></option>
          <option value="Sports"></option>
          <option value="News"></option>
          <option value="Education"></option>
          <option value="Weather"></option>
          <option value="SEO"></option>
          <option value="Trends"></option>
        </datalist>
      </div>
      <div class="row8">
        <button type="reset">RESET</button>
        <button type="submit">CREATE</button>
      </div>
    </form>
  </div>
</main>
<%- include("partials/footer") %>
