<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog Creation</title>
    <link
      rel="shortcut icon"
      href="https://static.vecteezy.com/system/resources/previews/015/425/993/non_2x/unique-letter-or-word-tb-sans-serif-cut-and-merge-connect-font-on-top-down-image-graphic-icon-logo-design-abstract-concept-stock-can-be-used-as-symbol-related-to-initial-or-sport-tech-vector.jpg"
      type="image/x-icon"
    />
    <link
      href="https://cdn.quilljs.com/1.3.6/quill.snow.css"
      rel="stylesheet"
    />
    <meta name="google-adsense-account" content="ca-pub-6153573963834456">
    <!-- Google tag (gtag.js) -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-MZ6F6Z0F88"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-MZ6F6Z0F88");
    </script>

    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
      rel="stylesheet"
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="../stylesheets/blogCreation.css" />
  </head>
  <body>
    <div class="container">
      <header class="header" id="header">
        <nav class="navbar container">
          <a href="/" class="brand">BLOGAT</a>
          <div class="burger" id="burger">
            <span class="burger-line"></span>
            <span class="burger-line"></span>
            <span class="burger-line"></span>
          </div>
          <span class="overlay"></span>
          <div class="menu" id="menu">
            <ul class="menu-inner">
              <li class="menu-item">
                <a class="menu-link" id="home" href="/">Home</a>
              </li>
              <li class="menu-item">
                <a class="menu-link" id="aboutUs" href="/About">About</a>
              </li>
              <li class="menu-item">
                <a class="menu-link" id="contactUs" href="/Contact">Contact</a>
              </li>
              <li class="menu-item">
                <a class="menu-link" id="adminPanel" href="/admin/adminPanel"
                  >Admin Panel</a
                >
              </li>
              <li class="menu-item">
                <a class="menu-link" id="createBlog" href="/blogCreation"
                  >Create Blog</a
                >
              </li>
            </ul>
          </div>
          <span><i class="bx bx-search search-toggle"></i></span>
          <div class="search-block">
            <form class="search-form">
              <span><i class="bx bx-arrow-back search-cancel"></i></span>
              <input
                type="search"
                name="search"
                class="search-input"
                placeholder="Search here..."
              />
            </form>
          </div>
        </nav>
      </header>
      <form action="/blog/blogCreation" method="post">
        <div class="row1">
          <input
            type="text"
            name="author"
            placeholder="Author"
            list="author"
            value="Ali Raza"
            required
          />
          <datalist id="author">
            <option value="Ali Raza"></option>
          </datalist>
          <input type="text" name="title" placeholder="title" required />
        </div>
        <div class="row2">
          <input
            type="text"
            list="category-list"
            name="category"
            placeholder="Category"
            required
          />
          <datalist id="category-list">
            <option value="Technology"></option>
            <option value="Travel"></option>
            <option value="Sports"></option>
            <option value="News"></option>
            <option value="Education"></option>
            <option value="Weather"></option>
            <option value="SEO"></option>
            <option value="Trends"></option>
          </datalist>
          <input
            type="text"
            list="category-list"
            name="tags"
            placeholder="Tag"
            required
          />
        </div>
        <div class="row3">
          <input type="text" name="imageUri" placeholder="Image url" required />
          <datalist id="category-list">
            <option value="Technology"></option>
            <option value="Travel"></option>
            <option value="Sports"></option>
            <option value="News"></option>
            <option value="Education"></option>
            <option value="Weather"></option>
            <option value="SEO"></option>
            <option value="Trends"></option>
          </datalist>

          <!-- Hidden input to store Quill's HTML content -->
          <input type="hidden" name="description" id="description" />
          <textarea
            name="description"
            id="description"
            placeholder="Content"
            required
          ></textarea>
        </div>
        <div class="row4">
          <button type="reset">Reset</button>
          <button type="submit">Submit</button>
        </div>
      </form>
    </div>
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script>
      const quill = new Quill('#editor', {
        theme: 'snow'
      });
    
      // When submitting form, copy the Quill HTML into the hidden input
      const form = document.querySelector('form');
      form.onsubmit = function () {
        const descriptionInput = document.querySelector('#description');
        descriptionInput.value = quill.root.innerHTML;
      };
    </script>
    <script src="../javascript/script.js"></script>
    <script
      src="https://kit.fontawesome.com/a076d05399.js"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
