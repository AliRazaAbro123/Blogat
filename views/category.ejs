<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Categorised</title>
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
      rel="stylesheet"
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="../stylesheets/category.css" />
  </head>
  <body>
    <div class="container">
      <header class="header" id="header">
        <nav class="navbar container">
          <a href="/" class="brand">BLOGAT</a>
          <div class="burger" id="burger">
            <span class="burger-line"></span>
            <span class="burger-line"></span>
            <span class="burger-line"></span>
          </div>
          <span class="overlay"></span>
          <div class="menu" id="menu">
            <ul class="menu-inner">
              <li class="menu-item">
                <a class="menu-link" id="home" href="/">Home</a>
              </li>
              <li class="menu-item">
                <a class="menu-link" id="aboutUs" href="/About-us">About Us</a>
              </li>
              <li class="menu-item">
                <a class="menu-link" id="contactUs" href="/Contact-us"
                  >Contact Us</a
                >
              </li>
            </ul>
          </div>
          <span><i class="bx bx-search search-toggle"></i></span>
          <div class="search-block">
            <form class="search-form">
              <span><i class="bx bx-arrow-back search-cancel"></i></span>
              <input
                type="search"
                name="search"
                class="search-input"
                placeholder="Search here..."
              />
            </form>
          </div>
        </nav>
      </header>
      <section class="homeTop">
        <div class="top">
          <h1>Fragments of Us: Love, Loss, and the Journey Beyond</h1>
          <p>
            Welcome to Blogat — your ultimate destination for fresh insights!
            Dive into handpicked content designed to inspire, entertain, and
            connect with readers around the world.
          </p>
          <h3>
            Explore more content in the
            <span><%= categoryName %></span> category
          </h3>
        </div>
        <div class="bottom">
          <h1>Explore Trending Topics</h1>
          <div class="buttons">
            <button>
              <a href="/category/Travel"
                ><i class="fa-solid fa-plane"></i> Travel
              </a>
            </button>
            <button>
              <a href="/category/Technology"
                ><i class="fa-solid fa-camera-retro"></i> Technology</a
              >
            </button>
            <button>
              <a href="/category/Sports"
                ><i class="fa-solid fa-basketball"></i> Sports</a
              >
            </button>
            <button>
              <a href="/category/News"><i class="fa-solid fa-file"></i> News</a>
            </button>
          </div>
          <div class="buttons">
            <button>
              <a href="/category/Weather"
                ><i class="fa-solid fa-cloud-sun"></i> Weather</a
              >
            </button>
            <button>
              <a href="/category/Education"
                ><i class="fa-solid fa-laptop"></i> Education</a
              >
            </button>
            <button>
              <a href="/category/Seo"><i class="fas fa-chart-bar"></i> SEO</a>
            </button>
            <button>
              <a href="/category/Seo"
                ><i class="fa-solid fa-person-praying"></i>Trends</a
              >
            </button>
          </div>
        </div>
      </section>
      <div class="blogsCards">
        <section class="blogs">
          <% categorizedBlogs.reverse().forEach(blog => { %>
          <div class="blog">
            <a href="/blog/<%= blog._id %>" class="Image">
              <img src="../assets/bg_2.jpg" alt="" />
            </a>
            <div class="content">
              <div class="tags">
                <h1><%= blog.tags %></h1>
              </div>
              <h3 class="creator">
                <%= blog.author %> <span><%= displayDate %></span>
              </h3>
              <a href="/blog/<%= blog._id %>" class="title">
                <%= blog.title %>
              </a>
              <p class="description">
                <%= blog.description.length > 120 ?
                blog.description.substring(0, 120) + "...." : blog.description
                %>
              </p>
              <button><a href="/blog/<%= blog._id %>">Discover More</a></button>
            </div>
          </div>
          <% }); %>
        </section>
        <section class="cards">
          <div class="about">
            <h3>ABOUT</h3>
            <div class="dpinfo">
              <div class="Image">
                <img src="../assets/1717442704967.jpg" alt="" />
              </div>
              <div class="aboutContent">
                <h1>Ali Raza</h1>
                <h3>Fullstack MERN Web Developer</h3>
              </div>
            </div>
            <p>
              Ali Raza shares thoughtful reflections on life, culture, and
              personal growth. His work blends creativity with experience,
              offering unique and meaningful perspectives.
            </p>
            <h3><i class="fas fa-map-marker-alt"></i> Sindh, Pakistan 🇵🇰</h3>
            <div class="links">
              <a href="https://www.facebook.com/profile.php?id=61552489011042"
                ><i class="fab fa-facebook fa-xl" title="Facebook"></i
              ></a>
              <a href="https://www.linkedin.com/in/aliraza1121/ "
                ><i class="fab fa-linkedin fa-xl" title="Linkedin"></i
              ></a>
              <a href="https://www.instagram.com/ali.stacker/"
                ><i class="fab fa-instagram fa-xl" title="Instagram"></i
              ></a>
              <a href="https://github.com/AliRazaAbro123"
                ><i class="fab fa-github fa-xl" title="GitHub"></i
              ></a>
            </div>
          </div>
        </section>
      </div>
      <footer>
        <div class="footerTop">
          <div class="titleSection">
            <h1>BLOGAT</h1>
            <p>
              BLOGAT is a blog that provides a platform for individuals to share
              their stories, insights, and experiences. It aims to foster
              connection and understanding through the power of storytelling.
            </p>
          </div>
          <div class="linksSection">
            <a href="/">Home</a>
            <a href="/About-us">About Us</a>
            <a href="/Contact-us">Contact Us</a>
          </div>
          <div class="personalLinks">
            <a href="https://www.facebook.com/profile.php?id=61552489011042"
              ><i class="fab fa-facebook fa-xl" title="Facebook"></i
            ></a>
            <a href="https://www.linkedin.com/in/aliraza1121/ "
              ><i class="fab fa-linkedin fa-xl" title="Linkedin"></i
            ></a>
            <a href="https://www.instagram.com/ali.stacker/"
              ><i class="fab fa-instagram fa-xl" title="Instagram"></i
            ></a>
            <a href="https://github.com/AliRazaAbro123"
              ><i class="fab fa-github fa-xl" title="GitHub"></i
            ></a>
          </div>
        </div>
        <div class="footerBottom">
          <h1>Made with ❤️ by Ali Raza • © 2025</h1>
          <div class="privicy">
            <a href="/Privacy-policy">Privacy Policy</a>
            <a href="/Terms-and-conditions">Terms and Conditions</a>
          </div>
        </div>
      </footer>
    </div>
    <!-- Scripts are included at the end of the body for better performance -->
    <script src="../javascript/script.js"></script>
    <script
      src="https://kit.fontawesome.com/a076d05399.js"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
